# WordPress plugin project local development environment
# Copy this file to .env in your working clone and adjust values.
# DO NOT commit .env — it contains local credentials.
#
# See WORKSPACE-SETUP.md for the full bootstrap guide.

# Docker project name — use a unique name per project to avoid container name collisions
COMPOSE_PROJECT_NAME=my_plugin_dev

# WordPress image — use the MINIMUM WordPress version your plugin supports.
# Default: wordpress:6.5-php8.1-apache (WP 6.5, PHP 8.1)
# Override for testing against newer versions:
#   WP_IMAGE=wordpress:6.9.4-php8.2-apache
WP_IMAGE=wordpress:6.5-php8.1-apache

# Database credentials (local dev only, do NOT use real creds here)
DB_ROOT_PASSWORD=rootpass_dev
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD=wp_pass_dev
DB_PREFIX=wp_

# Ports (change if these conflict with other local projects)
WP_PORT=8080
PMA_PORT=8081

# WordPress admin (used by wp core install in WORKSPACE-SETUP.md)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=dev@local.test

# Plugin folder names as mounted in docker-compose.yml
# Override these to match your actual folder names
PLUGIN_SLUG=my-plugin
CP_PLUGIN_SLUG=my-cp-plugin
